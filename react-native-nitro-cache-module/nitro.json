{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitrocachemodule"
  ],
  "ios": {
    "iosModuleName": "NitroCacheModule"
  },
  "android": {
    "androidNamespace": [
      "nitrocachemodule"
    ],
    "androidCxxLibName": "NitroCacheModule"
  },
  "autolinking": {
    "NitroCacheModule": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridNitroCacheModule"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridNitroCacheModule"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}